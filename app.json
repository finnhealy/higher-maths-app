{
  "expo": {
    "name": "Higher Maths",
    "slug": "higher-maths-app2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "Highermaths",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.finnhealy.higher-maths-app2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.finnhealy.highermathsapp2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "Higher Maths Garden Practice",
      "shortName": "Higher Maths",
      "lang": "en-GB",
      "scope": "/",
      "themeColor": "#208AEF",
      "backgroundColor": "#F8FAFC",
      "description": "Scottish Higher Maths lessons, practice questions, progress tracking, and a study garden.",
      "display": "standalone",
      "startUrl": "/",
      "orientation": "portrait",
      "barStyle": "black-translucent"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-notifications",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "root": "app"
      },
      "eas": {
        "projectId": "1ea7a541-3646-4796-aa10-2d9929ea8160"
      }
    }
  }
}
